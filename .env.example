# Copy this file to `.env` and fill in the values.
# `docker compose` automatically loads `.env` from the project root.
#
# ------------------------------------------------------------------
# Mode A — Connect to REAL AWS SQS (Option 1)
# ------------------------------------------------------------------
# Leave SQS_ENDPOINT_URL empty so boto3 builds the correct regional
# endpoint from AWS_DEFAULT_REGION and talks directly to AWS.
# Do NOT put a queue URL here — that causes:
#   "InvalidAction ... ListQueues is not valid for this endpoint".
SQS_ENDPOINT_URL=

# Your AWS credentials (from `aws configure` / IAM user / STS).
AWS_ACCESS_KEY_ID=EXAMPLE
AWS_SECRET_ACCESS_KEY=EXAMPLEKEY
# Only needed for temporary credentials (SSO / assumed role); otherwise leave empty.
AWS_SESSION_TOKEN=

# Region where your queues live.
AWS_DEFAULT_REGION=EXAMPLEREGION

# Start with:
#   sudo docker compose up --build -d backend frontend
#
# ------------------------------------------------------------------
# Mode B — Use LocalStack (default local development)
# ------------------------------------------------------------------
# SQS_ENDPOINT_URL=http://localstack:4566
# AWS_ACCESS_KEY_ID=test
# AWS_SECRET_ACCESS_KEY=test
# AWS_SESSION_TOKEN=
# AWS_DEFAULT_REGION=test
#
# Start with:
#   sudo docker compose --profile localstack up --build -d

# ------------------------------------------------------------------
# Backend tuning (optional)
# ------------------------------------------------------------------
# Long-poll wait (seconds) used by the move/redrive endpoints when
# receiving messages from SQS. Higher values reduce premature empty
# receives on distributed queues. Valid range: 0–20 (SQS limit).
# SQS_MOVE_POLL_WAIT_SECONDS=5
#
# Maximum number of consecutive empty receives before move/redrive
# loops give up.
# SQS_MOVE_MAX_ATTEMPTS=5
